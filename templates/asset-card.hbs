<article class="fx-browser-card" data-asset-id="{{id}}" title="{{path}}">
  <div class="fx-browser-card-media">
    <video src="{{path}}" autoplay loop muted playsinline loading="lazy"></video>
  </div>
  <div class="fx-browser-card-body">
    <h3>{{name}}</h3>
    <div class="fx-browser-card-badges">
      <span>{{categoryLabel}}</span>
      <span>{{playback}}</span>
    </div>
  </div>
</article>
