<div class="fx-browser-shell">
  <header class="fx-browser-topbar">
    <div class="fx-browser-search">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="search" data-search value="{{query}}" placeholder="{{localize 'fx-browser.search.placeholder'}}" autocomplete="off">
    </div>
    <button type="button" data-source-panel-toggle>
      <i class="fa-solid fa-gear"></i>
      Sources
    </button>
    <button type="button" data-action="rescan">
      <i class="fa-solid fa-rotate"></i>
      {{localize "fx-browser.actions.rescan"}}
    </button>
  </header>

  <div class="fx-browser-content">
    <nav class="fx-browser-categories" aria-label="FX Browser tabs">
      <div class="fx-browser-nav-section">
        <button type="button" class="{{#if tabs.all}}active{{/if}}" data-special-filter="all">ALL</button>
        <button type="button" class="{{#if tabs.favorites}}active{{/if}}" data-special-filter="favorites">FAVORIS</button>
        <button type="button" data-folder-create>+ Onglet</button>
      </div>

      <div class="fx-browser-nav-section">
        {{#each tabs.folders}}
          <div class="fx-browser-tab-row">
            <button type="button" class="{{#if active}}active{{/if}}" data-folder-filter="{{id}}">
              {{name}}
            </button>
            <button type="button" title="Renommer" data-folder-rename="{{id}}">
              <i class="fa-solid fa-pen"></i>
            </button>
            <button type="button" title="Supprimer" data-folder-delete="{{id}}">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        {{/each}}
      </div>

      {{#if showSources}}
        <div class="fx-browser-nav-section fx-browser-source-manager">
          <h2>Sources Origin Vault</h2>
          {{#unless originVaultAvailable}}
            <p>Origin Vault absent ou inactif. Les sources manuelles restent disponibles.</p>
          {{/unless}}
          <div class="fx-browser-source-actions">
            <button type="button" data-source-add>Ajouter</button>
            <button type="button" data-source-rescan>Rescanner</button>
          </div>
          {{#each configuredSources}}
            <div class="fx-browser-source-row">
              <input type="checkbox" title="Activer / desactiver" data-source-toggle="{{id}}" {{#if enabled}}checked{{/if}}>
              <div class="fx-browser-source-main" title="{{path}}">
                <span>Origin Vault - {{name}}</span>
                <small>{{path}}</small>
              </div>
              <span class="fx-browser-source-count">{{count}} FX</span>
              <button type="button" class="fx-browser-source-remove" title="Retirer" data-source-remove="{{id}}">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
          {{/each}}
        </div>
      {{/if}}
    </nav>

    <main class="fx-browser-grid" aria-live="polite">
      {{#if hasAssets}}
        {{#each assets}}
          {{> "modules/fx-browser/templates/asset-card.hbs" this}}
        {{/each}}
      {{else}}
        <div class="fx-browser-empty">{{emptyMessage}}</div>
      {{/if}}
    </main>

    <aside class="fx-browser-preview-panel">
      <div data-preview></div>

      {{#if selectedAsset}}
        <section class="fx-browser-asset-details">
          <h2>{{selectedAsset.displayName}}</h2>
          <dl>
            <dt>Nom original</dt><dd>{{selectedAsset.originalName}}</dd>
            <dt>Categorie</dt><dd>{{selectedAsset.categoryLabel}}</dd>
            <dt>Source</dt><dd>{{selectedAsset.sourceName}}</dd>
            <dt>Favori</dt><dd>{{selectedAsset.favoriteLabel}}</dd>
            <dt>Onglets</dt><dd>{{selectedAsset.folderNames}}</dd>
            <dt>Chemin</dt><dd title="{{selectedAsset.path}}">{{selectedAsset.path}}</dd>
          </dl>
          <div class="fx-browser-asset-actions">
            <button type="button" data-asset-action="rename">Renommer</button>
            <button type="button" data-asset-action="favorite">Favori</button>
            <button type="button" data-asset-action="add-tab">Ajouter a onglet</button>
            <button type="button" data-asset-action="copy-path">Copier chemin</button>
          </div>
        </section>
      {{/if}}

      {{> "modules/fx-browser/templates/overlay-list.hbs"}}
      {{> "modules/fx-browser/templates/overlay-controls.hbs"}}
    </aside>
  </div>

  {{#if contextMenu}}
    <div class="fx-browser-context-menu" style="left: {{contextMenu.x}}px; top: {{contextMenu.y}}px;">
      <button type="button" data-context-action="rename">Renommer</button>
      <button type="button" data-context-action="favorite">
        {{#if contextMenu.isFavorite}}Retirer des favoris{{else}}Ajouter aux favoris{{/if}}
      </button>
      <div class="fx-browser-context-group">
        <span>Ajouter a un onglet</span>
        {{#each contextMenu.folders}}
          <button type="button" data-context-action="move" data-folder-id="{{id}}">{{name}}</button>
        {{/each}}
      </div>
      {{#if contextMenu.hasCurrentFolder}}
        <button type="button" data-context-action="remove-folder">Retirer de cet onglet</button>
      {{/if}}
      <button type="button" data-context-action="copy-path">Copier chemin</button>
      <button type="button" data-context-action="preview">Previsualiser</button>
    </div>
  {{/if}}

  {{#if formState}}
    <div class="fx-browser-form-backdrop">
      <form class="fx-browser-inline-form" data-fx-form>
        <h2>{{formState.title}}</h2>
        {{#if formState.isSource}}
          <label>
            <span>Nom</span>
            <input name="name" type="text" value="{{formState.name}}">
          </label>
          <label>
            <span>Chemin / identifiant</span>
            <input name="path" type="text" value="{{formState.path}}">
          </label>
        {{/if}}
        {{#if formState.isNameForm}}
          <label>
            <span>Nom</span>
            <input name="name" type="text" value="{{formState.name}}">
          </label>
        {{/if}}
        {{#if formState.isMove}}
          <label>
            <span>Onglet</span>
            <select name="folderId">
              {{#each formState.folders}}
                <option value="{{id}}">{{name}}</option>
              {{/each}}
            </select>
          </label>
        {{/if}}
        {{#if formState.isConfirm}}
          <p>{{formState.message}}</p>
        {{/if}}
        <div class="fx-browser-form-actions">
          <button type="submit">{{#if formState.submitLabel}}{{formState.submitLabel}}{{else}}Valider{{/if}}</button>
          <button type="button" data-form-cancel>Annuler</button>
        </div>
      </form>
    </div>
  {{/if}}

  <footer class="fx-browser-placement">
    <label>
      <span>{{localize "fx-browser.placement.width"}}</span>
      <input data-placement name="width" type="number" min="0.25" max="20" step="0.25" value="{{placement.width}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.height"}}</span>
      <input data-placement name="height" type="number" min="0.25" max="20" step="0.25" value="{{placement.height}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.alpha"}}</span>
      <input data-placement name="alpha" type="number" min="0" max="1" step="0.05" value="{{placement.alpha}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.rotation"}}</span>
      <input data-placement name="rotation" type="number" min="-360" max="360" step="1" value="{{placement.rotation}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.elevation"}}</span>
      <input data-placement name="elevation" type="number" step="1" value="{{placement.elevation}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.zIndex"}}</span>
      <input data-placement name="zIndex" type="number" step="1" value="{{placement.zIndex}}">
    </label>
    <label class="fx-browser-placement-name">
      <span>{{localize "fx-browser.placement.name"}}</span>
      <input data-placement name="name" type="text" value="{{placement.name}}">
    </label>
    <label class="fx-browser-loop">
      <input data-placement name="loop" type="checkbox" {{#if placement.loop}}checked{{/if}}>
      <span>{{localize "fx-browser.placement.loop"}}</span>
    </label>
    <label class="fx-browser-loop">
      <input data-placement name="visible" type="checkbox" {{#if placement.visible}}checked{{/if}}>
      <span>{{localize "fx-browser.placement.visible"}}</span>
    </label>
    <label class="fx-browser-loop">
      <input data-placement name="locked" type="checkbox" {{#if placement.locked}}checked{{/if}}>
      <span>{{localize "fx-browser.placement.locked"}}</span>
    </label>
  </footer>
</div>
