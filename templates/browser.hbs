<div class="fx-browser-shell">
  <header class="fx-browser-topbar">
    <div class="fx-browser-search">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="search" data-search value="{{query}}" placeholder="{{localize 'fx-browser.search.placeholder'}}" autocomplete="off">
    </div>
    <button type="button" data-action="rescan">
      <i class="fa-solid fa-rotate"></i>
      {{localize "fx-browser.actions.rescan"}}
    </button>
  </header>

  <div class="fx-browser-content">
    <nav class="fx-browser-categories" aria-label="{{localize 'fx-browser.categories.label'}}">
      <div class="fx-browser-nav-section">
        <button type="button" class="{{#if librarySections.all}}active{{/if}}" data-special-filter="all">Toutes les sources</button>
        <button type="button" class="{{#if librarySections.favorites}}active{{/if}}" data-special-filter="favorites">Favoris</button>
        <button type="button" class="{{#if librarySections.personal}}active{{/if}}" data-special-filter="personal">Mes effets</button>
      </div>
      <div class="fx-browser-nav-section" data-folder-list>
        <h2>Dossiers personnels</h2>
        {{#each folders}}
          <button type="button" class="{{#if active}}active{{/if}}" data-folder-filter="{{id}}">
            {{name}}
          </button>
        {{/each}}
      </div>
      <div class="fx-browser-nav-section">
        <h2>Sources détectées</h2>
        {{#each sources}}
          <button type="button" class="{{#if active}}active{{/if}}" data-source-filter="{{id}}" title="{{path}}">
            <span>{{name}}</span>
            <small>{{path}} · {{count}}</small>
          </button>
        {{/each}}
      </div>
      <div class="fx-browser-nav-section">
        <h2>Catégories</h2>
      {{#each categories}}
        <button type="button" class="{{#if active}}active{{/if}}" data-action="selectCategory" data-category="{{id}}">
          {{label}}
        </button>
      {{/each}}
      </div>
    </nav>

    <main class="fx-browser-grid" aria-live="polite">
      {{#if hasAssets}}
        {{#each assets}}
          {{> "modules/fx-browser/templates/asset-card.hbs" this}}
        {{/each}}
      {{else}}
        <div class="fx-browser-empty">{{emptyMessage}}</div>
      {{/if}}
    </main>

    <aside class="fx-browser-preview-panel">
      <div data-preview></div>
      {{> "modules/fx-browser/templates/overlay-list.hbs"}}
      {{> "modules/fx-browser/templates/overlay-controls.hbs"}}
    </aside>
  </div>

  <footer class="fx-browser-placement">
    <label>
      <span>{{localize "fx-browser.placement.width"}}</span>
      <input data-placement name="width" type="number" min="0.25" max="20" step="0.25" value="{{placement.width}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.height"}}</span>
      <input data-placement name="height" type="number" min="0.25" max="20" step="0.25" value="{{placement.height}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.alpha"}}</span>
      <input data-placement name="alpha" type="number" min="0" max="1" step="0.05" value="{{placement.alpha}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.rotation"}}</span>
      <input data-placement name="rotation" type="number" min="-360" max="360" step="1" value="{{placement.rotation}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.elevation"}}</span>
      <input data-placement name="elevation" type="number" step="1" value="{{placement.elevation}}">
    </label>
    <label>
      <span>{{localize "fx-browser.placement.zIndex"}}</span>
      <input data-placement name="zIndex" type="number" step="1" value="{{placement.zIndex}}">
    </label>
    <label class="fx-browser-placement-name">
      <span>{{localize "fx-browser.placement.name"}}</span>
      <input data-placement name="name" type="text" value="{{placement.name}}">
    </label>
    <label class="fx-browser-loop">
      <input data-placement name="loop" type="checkbox" {{#if placement.loop}}checked{{/if}}>
      <span>{{localize "fx-browser.placement.loop"}}</span>
    </label>
    <label class="fx-browser-loop">
      <input data-placement name="visible" type="checkbox" {{#if placement.visible}}checked{{/if}}>
      <span>{{localize "fx-browser.placement.visible"}}</span>
    </label>
    <label class="fx-browser-loop">
      <input data-placement name="locked" type="checkbox" {{#if placement.locked}}checked{{/if}}>
      <span>{{localize "fx-browser.placement.locked"}}</span>
    </label>
  </footer>
</div>
